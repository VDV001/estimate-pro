# Database
DATABASE_URL=postgres://user:password@localhost:5432/estimatepro?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=estimatepro
S3_USE_SSL=false

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Server
SERVER_PORT=8080

# Composio (Notifications via Gmail & Telegram)
COMPOSIO_API_KEY=
COMPOSIO_GMAIL_ACCOUNT_ID=
COMPOSIO_TELEGRAM_ACCOUNT_ID=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Telegram Bot (Esti)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

# LLM Provider (claude, openai, grok, ollama)
LLM_PROVIDER=claude
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=
